					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[train]]></Name>
						<Type><![CDATA[Train]]></Type>
					</Parameter>
					<Body><![CDATA[Agent car = train.getCar(0);
if( car instanceof HopperCar ) return stopLineN1;
if( car instanceof BoxCar ) return stopLineN2;
if( car instanceof OpenCar ) return stopLineN3;
if( car instanceof GondolaCar ) return stopLineN4;
if( car instanceof TankCar ) return stopLineN5;
return null;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[int]]></ReturnType>
					<Id>1612172936174</Id>
					<Name><![CDATA[carsOfSameType]]></Name>
					<X>80</X><Y>1060</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[train]]></Name>
						<Type><![CDATA[Train]]></Type>
					</Parameter>
					<Body><![CDATA[Agent firstCar = train.getFirst();
int n = 1;
while( train.getCar(n).getClass() == firstCar.getClass() )
	n++;
return n;]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[Agent]]></ReturnType>
					<Id>1612172936176</Id>
					<Name><![CDATA[carSetup]]></Name>
					<X>80</X><Y>940</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[index]]></Name>
						<Type><![CDATA[int]]></Type>
					</Parameter>
					<Body><![CDATA[if (index==0) return new Locomotive();
int i = uniform_discr(1, 5);
switch (i) {
 case 1: return new OpenCar();
 case 2: return new BoxCar();
 case 3: return new GondolaCar();
 case 4: return new HopperCar();
 default: return new TankCar();   
}]]></Body>
				</Function>
			</Functions>
